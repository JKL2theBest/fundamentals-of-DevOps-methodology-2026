# Этап 1: Сборщик (Builder)
# Используем конкретный, минималистичный образ.
FROM python:3.11-slim-bullseye AS builder

# Устанавливаем рабочую директорию.
WORKDIR /app

# Создаем виртуальное окружение для изоляции зависимостей.
RUN python -m venv /opt/venv
# venv в PATH, чтобы команды (pip, gunicorn) были доступны напрямую.
ENV PATH="/opt/venv/bin:$PATH"

# Сначала копируем только файл с зависимостями для кэширования этого слоя.
COPY requirements.txt .

# Устанавливаем зависимости, не сохраняя кэш, чтобы уменьшить размер слоя.
RUN pip install --no-cache-dir -r requirements.txt

# Копируем исходный код приложения.
COPY src/ .


# Этап 2: Финальный образ (Production)
FROM python:3.11-slim-bullseye

# Создаем специального пользователя и группу с ограниченными правами.
# '--system' флаг создает пользователя без домашней директории, предназначенного для запуска сервисов.
RUN addgroup --system appgroup && adduser --system --ingroup appgroup appuser

# Копируем виртуальное окружение с уже установленными зависимостями из сборщика.
COPY --from=builder /opt/venv /opt/venv

# Устанавливаем рабочую директорию.
WORKDIR /app

# Копируем код приложения из сборщика.
COPY --from=builder /app /app

# Рекурсивно меняем владельца рабочей директории на нашего non-root пользователя.
# Это гарантирует, что у процесса приложения будут права на запись в свою папку
# (например, для создания .sock файлов Gunicorn - а то была проблема с этим
# ну, либо можно было выполнять все от root, но это небезопасно!)
RUN chown -R appuser:appgroup /app

# Переключаемся на созданного пользователя.
USER appuser

# Указываем путь к исполняемым файлам Python из нашего виртуального окружения.
ENV PATH="/opt/venv/bin:$PATH"

# сообщаем Docker, что приложение внутри контейнера слушает порт 8000.
EXPOSE 8000

# Запускаем приложение через production-ready WSGI сервер.
CMD ["gunicorn", "--bind", "0.0.0.0:8000", "app:app"]
